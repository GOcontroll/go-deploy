#!/usr/bin/env python3
"""go-deploy — MQTT-driven update agent voor GOcontroll controllers."""

import configparser
import hashlib
import json
import logging
import os
import signal
import subprocess
import sys
import tarfile
import tempfile
import threading
import time
import urllib.request
from pathlib import Path

import paho.mqtt.client as mqtt

VERSION = "1.3.2"
CONFIG_PATH = os.environ.get("GO_DEPLOY_CONFIG", "/etc/go-deploy/go-deploy.conf")
APP_STATE_FILE = "/etc/go-deploy/current-app.json"

logging.basicConfig(
    level=logging.INFO,
    format="%(levelname)s go-deploy: %(message)s",
    stream=sys.stdout,
)
log = logging.getLogger("go-deploy")


def load_config(path: str) -> configparser.ConfigParser:
    cfg = configparser.ConfigParser()
    cfg["mqtt"] = {"broker": "localhost", "port": "1883"}
    cfg["agent"] = {"topic_prefix": "gocontroll"}
    if not cfg.read(path):
        log.error("Config niet gevonden: %s", path)
        sys.exit(1)
    for key in ("serial_number", "app_id"):
        if not cfg.get("agent", key, fallback=""):
            log.error("Verplicht veld ontbreekt in config: [agent] %s", key)
            sys.exit(1)
    return cfg


def read_app_state() -> dict:
    try:
        with open(APP_STATE_FILE, "r") as f:
            return json.load(f)
    except Exception:
        return {}


def write_app_state(version: str, app_id: str) -> None:
    try:
        os.makedirs(os.path.dirname(APP_STATE_FILE), exist_ok=True)
        with open(APP_STATE_FILE, "w") as f:
            json.dump({"version": version, "app_id": app_id}, f)
    except Exception as exc:
        log.warning("Kan app state niet opslaan: %s", exc)


def sha256_file(path: str) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def download_file(url: str, dest: str) -> None:
    log.info("Downloading %s", url)
    req = urllib.request.Request(
        url,
        headers={"User-Agent": "go-deploy/" + VERSION + " (GOcontroll)"},
    )
    with urllib.request.urlopen(req, timeout=120) as resp, open(dest, "wb") as f:
        while True:
            chunk = resp.read(65536)
            if not chunk:
                break
            f.write(chunk)
    log.info("Download klaar — %d bytes", os.path.getsize(dest))


def install_update(payload: dict) -> tuple:
    url = payload.get("download_url")
    version = payload.get("version", "onbekend")
    expected_sha256 = payload.get("sha256")

    if not url:
        return False, "download_url ontbreekt in MQTT payload"

    with tempfile.TemporaryDirectory(prefix="go-deploy-") as work:
        tarball = os.path.join(work, "update.tar.gz")

        try:
            download_file(url, tarball)
        except Exception as exc:
            return False, f"Download mislukt: {exc}"

        if expected_sha256:
            actual = sha256_file(tarball)
            if actual != expected_sha256:
                return False, (
                    f"SHA256 verificatie mislukt — "
                    f"verwacht={expected_sha256} ontvangen={actual}"
                )
            log.info("SHA256 verificatie OK")
        else:
            log.warning("Geen SHA256 in payload — verificatie overgeslagen")

        try:
            with tarfile.open(tarball, "r:gz") as tar:
                tar.extractall(work)
            log.info("Tarball uitgepakt")
        except Exception as exc:
            return False, f"Uitpakken mislukt: {exc}"

        post_install = os.path.join(work, "files", "post-install.sh")
        if os.path.isfile(post_install):
            os.chmod(post_install, 0o755)
            log.info("post-install.sh uitvoeren")
            result = subprocess.run(
                ["/bin/bash", post_install],
                cwd=work,
                capture_output=True,
                text=True,
                timeout=300,
            )
            if result.stdout.strip():
                log.info("post-install stdout:\n%s", result.stdout.strip())
            if result.stderr.strip():
                log.warning("post-install stderr:\n%s", result.stderr.strip())
            if result.returncode != 0:
                return False, f"post-install.sh afgebroken met exitcode {result.returncode}"
        else:
            log.warning("Geen post-install.sh in tarball — handmatige installatie vereist")

    log.info("Update naar versie %s succesvol afgerond", version)
    return True, ""


class Agent:
    def __init__(self, cfg: configparser.ConfigParser):
        self.serial = cfg["agent"]["serial_number"].strip()
        self.app_id = cfg["agent"]["app_id"].strip()
        self.prefix = cfg["agent"].get("topic_prefix", "gocontroll").strip()
        self.broker   = cfg["mqtt"]["broker"].strip()
        self.port     = int(cfg["mqtt"].get("port", 1883))
        self.username = cfg["mqtt"].get("username", "").strip() or None
        self.password = cfg["mqtt"].get("password", "").strip() or None

        self.cmd_topic        = f"{self.prefix}/{self.serial}/cmd/update"
        self.status_topic     = f"{self.prefix}/{self.serial}/status/update"
        self.cmd_tunnel_topic    = f"{self.prefix}/{self.serial}/cmd/tunnel"
        self.status_tunnel_topic = f"{self.prefix}/{self.serial}/status/tunnel"
        self._busy = False
        self._tunnel_timer: threading.Timer | None = None

        self.client = mqtt.Client(
            client_id=f"go-deploy-{self.serial}",
            protocol=mqtt.MQTTv311,
            clean_session=True,
        )
        if self.username:
            self.client.username_pw_set(self.username, self.password)
        self.client.reconnect_delay_set(min_delay=5, max_delay=60)
        self.client.on_connect = self._on_connect
        self.client.on_disconnect = self._on_disconnect
        self.client.on_message = self._on_message

    def _on_connect(self, client, _ud, _flags, rc):
        if rc == 0:
            log.info("Verbonden met broker %s:%d", self.broker, self.port)
            client.subscribe([(self.cmd_topic, 1), (self.cmd_tunnel_topic, 1)])
            log.info("Gesubscribed op: %s en %s", self.cmd_topic, self.cmd_tunnel_topic)
            state = read_app_state()
            if state.get("version"):
                pub = json.dumps({
                    "status": "running",
                    "version": state["version"],
                    "app_id": state.get("app_id", self.app_id),
                    "agent_version": VERSION,
                })
                client.publish(self.status_topic, pub, qos=1, retain=True)
                log.info("Geinstalleerde versie gepubliceerd: %s", state["version"])
        else:
            log.error("Verbinding geweigerd door broker (rc=%d)", rc)

    def _on_disconnect(self, _client, _ud, rc):
        if rc != 0:
            log.warning("Onverwacht verbroken (rc=%d) — herverbinden...", rc)

    def _on_message(self, client, _ud, msg):
        if msg.topic == self.cmd_tunnel_topic:
            self._handle_tunnel(client, msg)
        else:
            self._handle_update(client, msg)

    def _stop_cloudflared(self) -> None:
        """Stop cloudflared zo snel mogelijk: kort wachten op graceful exit, anders SIGKILL."""
        try:
            subprocess.run(
                ["systemctl", "stop", "cloudflared"],
                capture_output=True,
                timeout=2,
            )
        except subprocess.TimeoutExpired:
            log.warning("systemctl stop timeout — cloudflared SIGKILL")
            subprocess.run(
                ["systemctl", "kill", "-s", "SIGKILL", "cloudflared"],
                capture_output=True,
            )
            subprocess.run(
                ["systemctl", "stop", "cloudflared"],
                capture_output=True,
                timeout=5,
            )
        except Exception as exc:
            log.error("Stop cloudflared mislukt: %s", exc)

    def _handle_tunnel(self, client, msg):
        try:
            payload = json.loads(msg.payload.decode("utf-8"))
        except Exception as exc:
            log.error("Kan tunnel payload niet parsen: %s", exc)
            return
        duration = int(payload.get("duration", 3600))
        log.info("Tunnel opdracht ontvangen — %d seconden", duration)

        if self._tunnel_timer is not None:
            self._tunnel_timer.cancel()
            self._tunnel_timer = None

        if duration == 0:
            log.info("Stop commando ontvangen — cloudflared stoppen")
            self._stop_cloudflared()
            client.publish(self.status_tunnel_topic,
                json.dumps({"status": "stopped"}), qos=1)
            return

        result = subprocess.run(["systemctl", "start", "cloudflared"], capture_output=True)
        if result.returncode != 0:
            log.error("cloudflared starten mislukt: %s", result.stderr.decode())
            client.publish(self.status_tunnel_topic,
                json.dumps({"status": "error", "error": "start failed"}), qos=1)
            return

        log.info("cloudflared gestart, stopt over %d seconden", duration)
        client.publish(self.status_tunnel_topic,
            json.dumps({"status": "active", "duration": duration}), qos=1)

        def stop_tunnel():
            log.info("Tunnel timeout — cloudflared stoppen")
            self._stop_cloudflared()
            client.publish(self.status_tunnel_topic,
                json.dumps({"status": "stopped"}), qos=1)
            self._tunnel_timer = None

        self._tunnel_timer = threading.Timer(duration, stop_tunnel)
        self._tunnel_timer.daemon = True
        self._tunnel_timer.start()

    def _handle_update(self, client, msg):
        if self._busy:
            log.warning("Update al bezig — inkomend bericht genegeerd")
            return
        self._busy = True
        try:
            payload = json.loads(msg.payload.decode("utf-8"))
        except Exception as exc:
            log.error("Kan MQTT payload niet parsen: %s", exc)
            self._busy = False
            return

        version = payload.get("version", "onbekend")
        log.info("Update opdracht ontvangen — versie=%s app_id=%s", version, self.app_id)

        ok, error = install_update(payload)

        status_payload = json.dumps({
            "status": "success" if ok else "failed",
            "version": version,
            "app_id": self.app_id,
            "agent_version": VERSION,
            **({"error": error} if error else {}),
        })
        client.publish(self.status_topic, status_payload, qos=1, retain=True)

        if ok:
            write_app_state(version, self.app_id)
            log.info("Update geslaagd — versie %s geinstalleerd", version)
        else:
            log.error("Update mislukt — %s", error)

        self._busy = False

    def run(self):
        log.info(
            "go-deploy v%s gestart — serial=%s app_id=%s broker=%s:%d",
            VERSION, self.serial, self.app_id, self.broker, self.port,
        )

        def _shutdown(sig, _frame):
            log.info("Signaal %d ontvangen — afsluiten", sig)
            self.client.loop_stop()
            self.client.disconnect()
            sys.exit(0)

        signal.signal(signal.SIGTERM, _shutdown)
        signal.signal(signal.SIGINT, _shutdown)

        self.client.connect_async(self.broker, self.port, keepalive=60)
        self.client.loop_start()

        while True:
            time.sleep(1)


def main():
    cfg = load_config(CONFIG_PATH)
    Agent(cfg).run()


if __name__ == "__main__":
    main()
